# Copy this file to ".env" (same folder) and fill in your real key.
# Never commit the real ".env" file.
#
# Get a FREE API key from Groq (no credit card needed):
#   1. Go to https://console.groq.com/keys
#   2. Sign up / log in
#   3. Click "Create API Key", copy it, and paste it below

AI_API_KEY=your_groq_api_key_here

# --- Optional, only needed once you deploy publicly ---

# Protects the /admin/stats endpoint (visit counts, signup counts, demo
# key usage). Set this to something private once deployed. Without it set,
# the admin stats endpoint is unreachable — it fails closed, not open.
ADMIN_KEY=

# Set to "production" when deployed (hides the /docs and /redoc API
# explorer pages, which have no reason to be public). Leave as
# "development" for local use.
ENVIRONMENT=development

# Most hosts (Render, Railway, etc.) set this automatically — you
# shouldn't need to set it yourself.
PORT=8000
